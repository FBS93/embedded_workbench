{
    "cmake.sourceDirectory": "${workspaceFolder}",
    "workbench.tree.indent": 16,
    "workbench.tree.expandMode": "doubleClick",
    "editor.autoIndent": "full",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.detectIndentation": false,
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "editor.formatOnSave": true
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "editor.formatOnSave": true
    },
    "[asm]": {
        "editor.formatOnSave": false
    },
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": "\\.S$",
                "cmd": "python3 ${workspaceFolder}/tools/asm_format/asm_format.py ${file}"
            }
        ]
    },
    "git.autofetch": true,
    "git-graph.showStatusBarItem": false,
    "cmake.ctestArgs": [
        "--test-output-size-passed",
        "0",
        "--test-output-size-failed",
        "0"
    ],
    "debug.showInStatusBar": "always",
    "cmake.options.advanced": {
        "variant": { //Debug, Release,...
            "statusBarVisibility": "hidden",
        },
        "cpack": {
            "statusBarVisibility": "hidden",
        },
        "workflow": {
            "statusBarVisibility": "hidden",
        },
        "configurePreset": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "visible"
        },
        "buildPreset": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "folder": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "kit": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "build": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden",
        },
        "launch": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "debug": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "launchTarget": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "visible"
        },
        "buildTarget": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "visible"
        },
    },
    "VsCodeTaskButtons.showCounter": false,
    "VsCodeTaskButtons.tasks": [
        {
            "label": "🧰 WB toolbox",
            "tasks": [
                {
                    "label": "🌐 OpenCode web GUI",
                    "task": "run_opencode_web_gui"
                },
                {
                    "label": "🔄 Sync third-party repositories",
                    "task": "run_third_party_sync"
                },
                {
                    "label": "🔗 Connect Raspberry Pi (SSH)",
                    "task": "connect_rpi_ssh"
                }
            ],
            "tooltip": "Workbench toolbox"
        },
        {
            "label": "💻 SW toolbox",
            "tasks": [
                {
                    "label": "🔨 Build",
                    "task": "build"
                },
                {
                    "label": "🧹 Clean",
                    "task": "clean"
                },
                {
                    "label": "📃 Enable target logging",
                    "task": "run_target_logging_server"
                },
                {
                    "label": "🧼 Format all source files",
                    "task": "format",
                },
                {
                    "label": "🔎 Run linter",
                    "task": "lint"
                }
            ],
            "tooltip": "Software toolbox"
        },
        {
            "label": "🔌 HW toolbox",
            "tasks": [
                {
                    "label": "⚡ Open KiCad",
                    "task": "open_kicad"
                },
                {
                    "label": "💾 Save KiCad state",
                    "task": "save_kicad_state"
                },
                {
                    "label": "♻️ Restore KiCad state",
                    "task": "restore_kicad_state"
                },
                {
                    "label": "🧹 Clean KiCad runtime state",
                    "task": "clean_kicad_runtime_state"
                }
            ],
            "tooltip": "Hardware toolbox"
        },
        {
            "label": "📐 MECH toolbox",
            "tasks": [
                {
                    "label": "🧊 Open CQ-Editor",
                    "task": "open_cq_editor"
                }
            ],
            "tooltip": "Mechanical toolbox"
        },
    ],
    "files.associations": {
        "*.c": "c",
        "*.h": "c",
    }
}
