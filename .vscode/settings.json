{
    "cmake.sourceDirectory": "${workspaceFolder}",
    "workbench.tree.indent": 16,
    "workbench.tree.expandMode": "doubleClick",
    "editor.autoIndent": "full",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.detectIndentation": false,
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "editor.formatOnSave": true
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
        "editor.formatOnSave": true
    },
    "[asm]": {
        "editor.formatOnSave": false
    },
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": "\\.S$",
                "cmd": "python3 ${workspaceFolder}/tools/scripts/asm_format.py ${file}"
            }
        ]
    },
    "git.autofetch": true,
    "git-graph.showStatusBarItem": false,
    "cmake.ctestArgs": [
        "--test-output-size-passed",
        "0",
        "--test-output-size-failed",
        "0"
    ],
    "debug.showInStatusBar": "always",
    "cmake.options.advanced": {
        "variant": { //Debug, Release,...
            "statusBarVisibility": "hidden",
        },
        "cpack": {
            "statusBarVisibility": "hidden",
        },
        "workflow": {
            "statusBarVisibility": "hidden",
        },
        "configurePreset": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "visible"
        },
        "buildPreset": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "folder": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "kit": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "build": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden",
        },
        "launch": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "debug": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "hidden"
        },
        "launchTarget": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "visible"
        },
        "buildTarget": {
            "statusBarVisibility": "inherit",
            "inheritDefault": "visible"
        },
    },
    "VsCodeTaskButtons.showCounter": false,
    "VsCodeTaskButtons.tasks": [
        {
            "label": "🧰 Toolbox",
            "tasks": [
                {
                    "label": " 🌐 OpenCode web GUI",
                    "task": "run_opencode_web_gui"
                },
                {
                    "label": " 🔗 Connect Raspberry Pi (SSH)",
                    "task": "connect_rpi_ssh"
                },
                {
                    "label": " 📃 Enable target logging",
                    "task": "run_target_logging_server"
                },
                {
                    "label": "🧼 Format all source files",
                    "task": "format",
                }
            ],
            "tooltip": "Software tools"
        },
        {
            "label": "🔨 Build",
            "task": "build",
            "tooltip": "Build project",
        },
        {
            "label": "🧹 Clean",
            "task": "clean",
            "tooltip": "Clean build artifacts"
        }
    ],
    "files.associations": {
        "*.c": "c",
        "*.h": "c",
    }
}
